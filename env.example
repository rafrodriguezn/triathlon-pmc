# Garmin credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# Lactate Threshold Heart Rate (beats per minute)
LTHR=155

# How many days back to pull when syncing from Garmin (default 365)
SYNC_DAYS=365

# Anthropic API key — get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
